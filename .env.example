# Database
# MariaDB 접속 JDBC URL (jdbc:mariadb://host:port/db)
DB_URL=jdbc:mariadb://localhost:3306/hr
# DB 접속 계정명
DB_USERNAME=your_username
# DB 접속 비밀번호 (민감정보)
DB_PASSWORD=your_password

# Redis
# Redis 서버 호스트
REDIS_HOST=localhost
# Redis 서버 포트
REDIS_PORT=6379
# Redis 접속 비밀번호 (민감정보)
REDIS_PASSWORD=your_redis_password
# Redis 논리 DB 번호 (0~15)
REDIS_DATABASE=3

# Server
# 애플리케이션 HTTP 서버 포트
SERVER_PORT=8001

# Mail
# 알림/초대 메일 발송용 Gmail SMTP 계정
MAIL_USERNAME=your_mail@gmail.com
# Gmail 앱 비밀번호 (민감정보)
MAIL_PASSWORD=your_app_password

# JWT
# HR 자체토큰(HMAC) 폴백 서명키 — JWT_HR_SECRET 미설정 시에만 사용 (민감정보)
JWT_SECRET=your-jwt-secret-key-must-be-at-least-32-characters-long
# HR 자체토큰(HMAC) 주 서명키 (민감정보)
JWT_HR_SECRET=your-hr-jwt-secret-key-must-be-at-least-32-characters-long

# File
# 업로드 파일 저장 루트 경로 (프로필 이미지 등)
FILE_ROOT_PATH=/path/to/upload/files

# App
# 프론트엔드 기본 URL — 이메일 링크·CORS 허용 출처에 사용
FRONTEND_BASE_URL=http://localhost:3001

# SSO
# SSO 서버 API 기본 URL — 초대 API 호출 및 JWKS(RS256 검증) 엔드포인트 기준
SSO_API_URL=http://localhost:8000
# SSO client_credentials 서비스토큰 발급용 시크릿, admin 화면에서 발급 (민감정보)
SSO_CLIENT_SECRET=

# Logging (info / debug / trace / warn / error)
# 애플리케이션(com.porest.hr) 로그 레벨
LOG_LEVEL=info
# Hibernate SQL 로그 레벨
LOG_LEVEL_HIBERNATE=info
# 루트 로거 로그 레벨
LOG_LEVEL_ROOT=info

# P6Spy (true / false)
# P6Spy SQL 로깅 활성화 여부
P6SPY_ENABLED=true

# Swagger (true / false)
# Swagger UI / OpenAPI 문서 노출 여부 (운영 비활성 권장)
SWAGGER_ENABLED=true

# Error Display (운영에선 내부정보 노출 방지 위해 최소화 권장)
# 에러 응답에 스택트레이스 포함 (never | always | on-param)
ERROR_STACKTRACE=never
# 에러 응답에 에러 메시지 포함 (never | always | on-param)
ERROR_MESSAGE=never
# 에러 응답에 예외 클래스명 포함 (true | false)
ERROR_EXCEPTION=false
# 에러 응답에 바인딩(검증) 오류 목록 포함 (never | always | on-param)
ERROR_BINDING=never

# Cookie
# 세션 쿠키 Secure 속성 — HTTPS 전용 전송 여부 (true | false, 운영 true)
COOKIE_SECURE=false
# 세션 쿠키 SameSite 속성 (lax | strict | none)
COOKIE_SAME_SITE=lax
